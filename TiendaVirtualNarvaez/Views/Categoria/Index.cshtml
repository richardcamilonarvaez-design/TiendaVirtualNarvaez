@model List<TiendaVirtualNarvaez.Models.Categoria>

@{
    ViewData["Title"] = "Categoria";
}

<h2>Lista de Categorías</h2>

<a class="btn btn-primary" href="/Categoria/Create">Nueva Categoría</a>

<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@item.Estado</td>

                <td>
                    <a class="btn btn-warning"
                       href="/Categoria/Edit/@item.Id">Editar</a>

                    <a class="btn btn-danger"
                       href="/Categoria/Delete/@item.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>