@model List<TiendaVirtualNarvaez.Models.Categoria>

@{
    ViewData["Title"] = "Categoria";
}

<div class="container mt-4">

    <h2 class="mb-3">Lista de Categorías</h2>

    <a class="btn btn-success mb-3" href="/Categoria/Create">Nueva Categoría</a>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Descripcion</td>
                    <td>
                        <span class="badge @(item.Estado == "Activo" ? "bg-primary" : "bg-danger")">
                            @item.Estado
                        </span>
                    </td>
                    <td>
                        <a class="btn btn-info btn-sm text-white"
                           href="/Categoria/Details/@item.Id">Ver</a>

                        <a class="btn btn-warning btn-sm"
                           href="/Categoria/Edit/@item.Id">Editar</a>

                        <a class="btn btn-danger btn-sm"
                           href="/Categoria/Delete/@item.Id">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>