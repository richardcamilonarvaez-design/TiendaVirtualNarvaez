@model List<TiendaVirtualNarvaez.Models.Categoria>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Categorías";
    var rolSesion = Context.Session.GetString("Rol");
}

<div class="container mt-4 mb-5 pb-5">
    <h2 class="mb-4 text-center">Gestión de Categorías</h2>

    @* Solo el administrador puede crear nuevas categorías *@
    @if (rolSesion == "administrador")
    {
        <a class="btn btn-success mb-3 shadow-sm" href="/Categoria/Create">
            <i class="bi bi-plus-circle"></i> Nueva Categoría
        </a>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-tag"></i> Nombre</th>
                        <th><i class="bi bi-card-text"></i> Descripción</th>
                        <th class="text-center"><i class="bi bi-toggle-on"></i> Estado</th>
                        
                        @if (rolSesion == "administrador")
                        {
                            <th class="text-center">Acciones</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="font-weight-bold">@item.Nombre</td>
                            <td class="text-muted">@item.Descripcion</td>
                            <td class="text-center">
                                <span class="badge @(item.Estado == "Activo" ? "bg-success" : "bg-secondary") p-2">
                                    <i class="bi @(item.Estado == "Activo" ? "bi-check-circle" : "bi-x-circle")"></i>
                                    @item.Estado
                                </span>
                            </td>

                            @if (rolSesion == "administrador")
                            {
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-info btn-sm text-white" href="/Categoria/Details/@item.Id" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a class="btn btn-warning btn-sm" href="/Categoria/Edit/@item.Id" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a class="btn btn-danger btn-sm" href="/Categoria/Delete/@item.Id"
                                               title="Eliminar" onclick="return confirm('¿Está seguro de eliminar esta categoría?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>