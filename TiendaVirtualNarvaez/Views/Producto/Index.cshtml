@model List<TiendaVirtualNarvaez.Models.Producto>

@{
    ViewData["Title"] = "Producto";
}

<div class="container mt-4">
    <h2 class="mb-3">Lista de Productos</h2>

    <a class="btn btn-success mb-3" href="/Producto/Create">Nuevo Producto</a>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Categoria</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Precio.ToString("C0")</td>
                    <td>@item.Stock</td>
                    <td>@item.Categoria?.Nombre</td>

                    <td>
                        <a class="btn btn-info btn-sm text-white"
                           href="/Producto/Details/@item.Id">Ver</a>

                        <a class="btn btn-warning btn-sm"
                           href="/Producto/Edit/@item.Id">Editar</a>

                        <a class="btn btn-danger btn-sm"
                           href="/Producto/Delete/@item.Id">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>