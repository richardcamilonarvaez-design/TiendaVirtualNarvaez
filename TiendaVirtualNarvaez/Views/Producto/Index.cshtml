@model List<TiendaVirtualNarvaez.Models.Producto>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Productos";
    var rolSesion = Context.Session.GetString("Rol");
}

@* Añadimos mb-5 y pb-5 para que el footer no tape la última fila de la tabla *@
<div class="container mt-4 mb-5 pb-5">
    <h2 class="mb-4 text-center">Lista de Productos</h2>

    @* Solo el administrador puede crear productos *@
    @if (rolSesion == "administrador")
    {
        <a class="btn btn-success mb-3 shadow-sm" href="/Producto/Create">
            <i class="bi bi-plus-circle"></i> Nuevo Producto
        </a>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-box-seam"></i> Nombre</th>
                        <th><i class="bi bi-currency-dollar"></i> Precio</th>
                        <th><i class="bi bi-stack"></i> Stock</th>
                        <th><i class="bi bi-tag"></i> Categoría</th>

                        @if (rolSesion == "administrador")
                        {
                            <th class="text-center">Acciones</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="font-weight-bold">@item.Nombre</td>
                            <td>@item.Precio.ToString("C0")</td>
                            <td>
                                @* Badge dinámico para el stock *@
                                <span class="badge @(item.Stock > 5 ? "bg-light text-dark" : "bg-danger") border">
                                    @item.Stock unidades
                                </span>
                            </td>
                            <td>
                                <span class="text-muted">@(item.Categoria?.Nombre ?? "Sin categoría")</span>
                            </td>

                            @if (rolSesion == "administrador")
                            {
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-info btn-sm text-white" href="/Producto/Details/@item.Id" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a class="btn btn-warning btn-sm" href="/Producto/Edit/@item.Id" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a class="btn btn-danger btn-sm" href="/Producto/Delete/@item.Id"
                                               title="Eliminar" onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>