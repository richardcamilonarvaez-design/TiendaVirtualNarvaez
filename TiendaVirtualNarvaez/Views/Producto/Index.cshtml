@model List<TiendaVirtualNarvaez.Models.Producto>
@using Microsoft.AspNetCore.Http

@{
    var rolSesion = Context.Session.GetString("Rol");
}

<div class="container mt-4 mb-5 pb-5">
    <h2 class="mb-4 text-center">Productos</h2>

    @if (rolSesion == "administrador")
    {
        <a class="btn btn-success mb-3 shadow-sm" href="/Producto/Create">
            <i class="bi bi-plus-circle"></i> Nuevo Producto
        </a>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImagenUrl))
                    {
                        <img src="@item.ImagenUrl"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light" style="height:200px;">
                            <span class="text-muted">Sin imagen</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="card-text mb-2">
                            Precio: @item.Precio.ToString("C0") <br />
                            Stock: @item.Stock <br />
                            Categoría: @item.Categoria?.Nombre
                        </p>

                        <div class="mt-auto">
                            <a href="/Producto/Details/@item.Id" class="btn btn-info btn-sm text-white mb-1 w-100">Ver</a>
                            <a href="/Producto/Edit/@item.Id" class="btn btn-warning btn-sm mb-1 w-100">Editar</a>

                            @if (rolSesion == "administrador")
                            {
                                <a href="/Producto/Delete/@item.Id"
                                   class="btn btn-danger btn-sm w-100"
                                   onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                    Eliminar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>