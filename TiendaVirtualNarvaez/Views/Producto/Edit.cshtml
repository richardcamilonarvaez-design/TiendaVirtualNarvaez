@model TiendaVirtualNarvaez.Models.Producto

<div class="container mt-4 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h2 class="mb-4 text-center">Editar Producto</h2>

                <!-- Formulario con enctype para subir archivos -->
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label font-weight-bold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Precio" class="form-label font-weight-bold">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Precio" class="form-control" />
                            </div>
                            <span asp-validation-for="Precio" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Stock" class="form-label font-weight-bold">Stock</label>
                            <input asp-for="Stock" class="form-control" />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoriaId" class="form-label font-weight-bold">Categoría</label>
                        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <!-- Sección de imagen -->
                    <div class="mb-3">
                        <label>Imagen actual</label><br />
                        @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                        {
                            <img src="@Model.ImagenUrl" width="150" class="mb-2" />
                        }
                        else
                        {
                            <span class="text-muted">No hay imagen</span>
                        }
                    </div>

                    <div class="mb-3">
                        <label>Nueva imagen (opcional)</label>
                        <input type="file" name="imagen" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Actualizar</button>
                        <a href="/Producto" class="btn btn-secondary px-4">Volver</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>