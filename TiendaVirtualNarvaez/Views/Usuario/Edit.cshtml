@model TiendaVirtualNarvaez.Models.Usuario

@* Añadimos mb-5 (margin bottom) y pb-5 (padding bottom) para alejar el footer *@
<div class="container mt-4 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h2 class="mb-4 text-center">Editar Usuario</h2>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Correo</label>
                        <input asp-for="Correo" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Rol</label>
                        <input asp-for="Rol" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Celular</label>
                        <input asp-for="Celular" class="form-control" />
                        <span asp-validation-for="Celular" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Clave</label>
                        @* Agregué type="password" para que no se vea la clave al editar *@
                        <input asp-for="Clave" type="password" class="form-control" />
                        <span asp-validation-for="Clave" class="text-danger"></span>
                    </div>

                    <hr class="my-4"> @* my-4 da margen arriba y abajo de la línea *@

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Actualizar</button>
                        <a href="/Usuario" class="btn btn-secondary px-4">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
