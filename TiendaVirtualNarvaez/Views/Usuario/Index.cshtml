@model List<TiendaVirtualNarvaez.Models.Usuario>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Usuarios";
    var rolSesion = HttpContextAccessor.HttpContext.Session.GetString("Rol");
}

<div class="container mt-4 mb-5 pb-5">
    <h2 class="mb-4 text-center">Lista de Usuarios</h2>

    @* Solo el admin puede crear nuevos usuarios directamente desde aquí *@
    @if (rolSesion == "administrador")
    {
        <a class="btn btn-success mb-3 shadow-sm" href="/Usuario/Create">
            <i class="bi bi-plus-circle"></i> Nuevo Usuario
        </a>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Celular</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Correo</td>
                            <td>
                                <span class="badge @(item.Rol == "administrador" ? "bg-primary" : "bg-info text-dark")">
                                    @item.Rol
                                </span>
                            </td>
                            <td>@item.Celular</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a class="btn btn-info btn-sm text-white" href="/Usuario/Details/@item.Id">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>

                                    <a class="btn btn-warning btn-sm" href="/Usuario/Edit/@item.Id">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>

                                    @* Solo el admin ve el botón de eliminar *@
                                    @if (rolSesion == "administrador")
                                    {
                                        <a class="btn btn-danger btn-sm" href="/Usuario/Delete/@item.Id"
                                               onclick="return confirm('¿Estás seguro de eliminar este usuario?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>